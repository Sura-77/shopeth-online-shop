# ============================================================
#  .gitignore — ShopEth Online Shop System
# ============================================================

# ── Node.js ──────────────────────────────────────────────────
node_modules/
backend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ── Environment variables (NEVER commit these) ────────────────
.env
backend/.env
*.env
.env.local
.env.development
.env.production
.env.test

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
backend/logs/

# ── OS generated files ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editor files ────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── Test coverage ─────────────────────────────────────────────
coverage/
backend/coverage/
.nyc_output/

# ── Build output ──────────────────────────────────────────────
dist/
build/
out/

# ── Temporary files ───────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp

# ── Package lock (keep package-lock.json, ignore yarn.lock if not used)
yarn.lock

# ── MySQL dump files with real data (keep schema files) ───────
# Uncomment the line below if you don't want to commit sample data
# sample_data.sql
# more_products.sql

# ── Keep these SQL files (they are safe to commit) ────────────
# schema_v2.sql    ← table definitions only, no sensitive data
# procedures.sql   ← stored procedures, no sensitive data
# triggers.sql     ← triggers, no sensitive data
# views.sql        ← views, no sensitive data
