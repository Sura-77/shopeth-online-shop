# ============================================================
#  Environment Variables — copy this to .env and fill in values
#  NEVER commit the real .env file to version control
# ============================================================

# Server
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=online_shop_db

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
